# Configuracion del monitor de seguridad climatica
WEATHER_API_BASE_URL=https://api.meteo-sacyr.local/v1/weather/wind/current
WEATHER_API_KEY=REEMPLAZAR_POR_TOKEN_REAL
WEATHER_TIMEOUT_SECONDS=5
SAMPLING_INTERVAL_SECONDS=2
STALE_DATA_THRESHOLD_SECONDS=10
STALE_CYCLES_TO_FAIL_SAFE=2
GHOST_GUST_DELTA_THRESHOLD=20
WEATHER_USE_SIMULATOR=true
